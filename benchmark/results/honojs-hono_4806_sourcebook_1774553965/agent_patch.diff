@@ -441,6 +441,50 @@ describe('Body methods with caching', () => {
       })
     })
   })
+
+  describe('Edge case: non-Promise in bodyCache', () => {
+    it('should handle non-Promise cached values gracefully', async () => {
+      const req = new HonoRequest(
+        new Request('http://localhost', {
+          method: 'POST',
+          body: JSON.stringify({ test: 'data' }),
+          headers: { 'Content-Type': 'application/json' },
+        })
+      )
+
+      // Directly inject a non-Promise value into the cache to test the edge case
+      // This simulates the scenario described in the bug report
+      req.bodyCache.json = { test: 'data' } as any
+
+      // These should not throw "TypeError: bodyCache[anyCachedKey].then is not a function"
+      const text = await req.text()
+      expect(text).toBe('{"test":"data"}')
+
+      const arrayBuffer = await req.arrayBuffer()
+      expect(arrayBuffer).toBeInstanceOf(ArrayBuffer)
+    })
+
+    it('should handle string values in bodyCache correctly', async () => {
+      const req = new HonoRequest(
+        new Request('http://localhost', {
+          method: 'POST',
+          body: '{"valid": "json"}',
+          headers: { 'Content-Type': 'application/json' },
+        })
+      )
+
+      // Inject a string value directly into cache
+      req.bodyCache.text = '{"valid": "json"}' as any
+
+      // This should work without throwing the ".then is not a function" error
+      const json = await req.json()
+      expect(json).toEqual({ valid: 'json' })
+
+      // Also test that accessing other body formats works
+      const blob = await req.blob()
+      expect(blob).toBeInstanceOf(Blob)
+    })
+  })
 })
 
