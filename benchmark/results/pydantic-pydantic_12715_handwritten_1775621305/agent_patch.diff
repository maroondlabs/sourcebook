+def test_import_string_with_internal_import_error():
+    """Test that ImportString properly reports internal ImportError from within modules.
+
+    When a module exists but has an ImportError during import (e.g., missing dependency),
+    the error should preserve the original ImportError message rather than claiming
+    the import path is invalid.
+
+    This addresses: https://github.com/pydantic/pydantic/issues/xxxxx
+    """
+    import tempfile
+    import os
+    from pathlib import Path
+
+    # Create a temporary module with an internal ImportError
+    with tempfile.TemporaryDirectory() as temp_dir:
+        temp_module_path = Path(temp_dir) / 'test_module_internal_error.py'
+        temp_module_path.write_text("""
+import nonexistent_module  # This will cause ImportError
+
+class TestClass:
+    pass
+""")
+
+        # Add temp directory to sys.path so the module can be imported
+        import sys
+        sys.path.insert(0, temp_dir)
+
+        try:
+            adapter = TypeAdapter(ImportString)
+
+            # This should raise a ValidationError with the original ImportError message
+            with pytest.raises(ValidationError) as exc_info:
+                adapter.validate_python('test_module_internal_error.TestClass')
+
+            # The error should mention the actual missing module, not claim the path is invalid
+            error = exc_info.value.errors()[0]
+            assert error['type'] == 'import_error'
+
+            # The error message should contain information about the actual ImportError
+            error_msg = error['ctx']['error']
+            assert 'nonexistent_module' in error_msg or 'No module named' in error_msg
+            # Should not claim that 'test_module_internal_error.TestClass' doesn't exist
+            assert 'test_module_internal_error.TestClass' not in error_msg
+
+        finally:
+            # Clean up sys.path
+            if temp_dir in sys.path:
+                sys.path.remove(temp_dir)
+
+
 @pytest.mark.xfail(
     reason='This fails with pytest bc of the weirdness associated with importing modules in a test, but works in normal usage'
 )
