+
+    // Test for the specific issue described in the bug report
+    describe('Issue reproduction: parseBody() breaks subsequent text()/json() calls', () => {
+      it('should handle mixed cache entries correctly when validator caches FormData', async () => {
+        const req = new HonoRequest(
+          new Request('http://localhost', {
+            method: 'POST',
+            body: JSON.stringify({ event: 'push' }),
+            headers: { 'Content-Type': 'application/json' },
+          })
+        )
+
+        // Simulate the scenario where validator middleware caches a resolved FormData object
+        // This is what happens in src/validator/validator.ts line 121: c.req.bodyCache.formData = formData
+        const mockFormData = new FormData()
+        req.bodyCache.formData = mockFormData as any
+
+        // After the fix, this should work correctly instead of throwing an error
+        // The main point is that it doesn't crash with "TypeError: .then is not a function"
+        const text = await req.text()
+        expect(text).toMatch(/------formdata/) // FormData serializes to multipart format
+      })
+
+      it('should handle mixed cache entries correctly when a plain object is cached', async () => {
+        const req = new HonoRequest(
+          new Request('http://localhost', {
+            method: 'POST',
+            body: JSON.stringify({ event: 'push' }),
+            headers: { 'Content-Type': 'application/json' },
+          })
+        )
+
+        // Manually create another problematic scenario where a plain object is cached
+        req.bodyCache.json = { event: 'push' } as any
+
+        // After the fix, this should work correctly instead of throwing an error
+        const text = await req.text()
+        expect(text).toBe(JSON.stringify({ event: 'push' }))
+      })
+    })
   })
 })
 
