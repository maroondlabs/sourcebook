+def test_importstring_distinguishes_internal_vs_path_errors(tmp_path, monkeypatch):
+    """Test that ImportString properly distinguishes between path validation errors
+    and internal import errors within valid modules."""
+
+    # Create a module that exists but has internal import errors
+    (tmp_path / 'module_with_internal_error.py').write_text(
+        'import definitely_missing_dependency\n\nclass MyClass:\n    pass\n'
+    )
+    monkeypatch.syspath_prepend(tmp_path)
+
+    adapter = TypeAdapter(ImportString)
+
+    # Test 1: Internal import error should show the actual error without "Invalid python path:" prefix
+    with pytest.raises(ValidationError) as exc_info:
+        adapter.validate_python('module_with_internal_error.MyClass')
+
+    error = exc_info.value.errors()[0]
+    assert error['type'] == 'import_error'
+    # Should NOT contain "Invalid python path:" for internal errors
+    assert 'Invalid python path:' not in error['msg']
+    # Should show the actual internal error
+    assert 'definitely_missing_dependency' in error['msg']
+
+    # Test 2: Path validation error should still show "Invalid python path:" prefix
+    with pytest.raises(ValidationError) as exc_info:
+        adapter.validate_python('definitely_nonexistent_module.SomeClass')
+
+    error = exc_info.value.errors()[0]
+    assert error['type'] == 'import_error'
+    # Should contain "Invalid python path:" for path validation errors
+    assert 'Invalid python path:' in error['msg']
+    assert 'definitely_nonexistent_module' in error['msg']
+
+
