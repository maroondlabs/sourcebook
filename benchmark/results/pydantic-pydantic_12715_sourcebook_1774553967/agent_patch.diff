+class _InternalImportError(Exception):
+    """Exception used to distinguish import errors that occur within a valid module
+    from import errors that indicate the import path itself is invalid."""
+
+    def __init__(self, original_error: ImportError):
+        self.original_error = original_error
+        super().__init__(str(original_error))
+
+
+def _module_exists_in_path(module_path: str) -> bool:
+    """Check if a module file exists on the filesystem, even if it can't be imported."""
+    import sys
+    from pathlib import Path
+    import importlib.util
+
+    # Try using importlib.util.find_spec to locate the module without importing it
+    try:
+        spec = importlib.util.find_spec(module_path)
+        return spec is not None and spec.origin is not None
+    except (ImportError, ValueError, ModuleNotFoundError):
+        # If find_spec fails, the module doesn't exist
+        return False
+
