+    describe('should handle non-Promise values in bodyCache', () => {
+      it('text() should work when non-Promise values are manually cached', async () => {
+        const req = new HonoRequest(
+          new Request('http://localhost', {
+            method: 'POST',
+            body: JSON.stringify({ test: 'data' }),
+            headers: { 'Content-Type': 'application/json' },
+          })
+        )
+
+        // Simulate the scenario where a non-Promise value gets cached
+        // This could happen if some middleware or future parseBody implementation
+        // caches a plain object instead of a Promise
+        ;(req as any).bodyCache.parsedBody = { test: 'data' }
+
+        // This should not throw "bodyCache[anyCachedKey].then is not a function"
+        // Instead, it should fall back to reading from the raw request
+        const result = await req.text()
+        expect(result).toBe('{"test":"data"}')
+      })
+
+      it('json() should work when non-Promise values are manually cached', async () => {
+        const req = new HonoRequest(
+          new Request('http://localhost', {
+            method: 'POST',
+            body: JSON.stringify({ test: 'data' }),
+            headers: { 'Content-Type': 'application/json' },
+          })
+        )
+
+        // Simulate caching a plain object
+        ;(req as any).bodyCache.parsedBody = { cached: 'object' }
+
+        // Should handle the non-Promise cached value gracefully by falling back to raw
+        const result = await req.json()
+        expect(result).toEqual({ test: 'data' })
+      })
+    })
+
