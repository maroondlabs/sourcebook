+def _is_path_validation_error(dotted_path: str, error: ImportError) -> bool:
+    """Determine if an ImportError represents a path validation issue or an internal module error.
+
+    Returns True if the error is due to an invalid import path.
+    Returns False if the error is from within a valid module (e.g., missing dependencies).
+    """
+    import os
+    import sys
+    from importlib import util
+
+    # Parse the dotted path to get the module path (same logic as _import_string_logic)
+    components = dotted_path.strip().split(':')
+    module_path = components[0]
+
+    if not module_path:
+        return True  # Empty module name is always a path error
+
+    # If no colon and the path contains dots, we need to consider that the final
+    # part might be an attribute, so we should check multiple possible module paths
+    possible_module_paths = [module_path]
+    if len(components) == 1 and '.' in module_path:
+        # Also try the path with the last segment as an attribute
+        maybe_module_path, _ = module_path.rsplit('.', 1)
+        possible_module_paths.append(maybe_module_path)
+
+    # Handle ModuleNotFoundError specifically
+    if isinstance(error, ModuleNotFoundError):
+        error_msg = str(error)
+        # Check if the error is about any of the possible module paths
+        for mp in possible_module_paths:
+            if f"No module named '{mp}'" in error_msg:
+                return True  # The target module itself doesn't exist
+        # If the error mentions a different module name, it's likely a dependency issue
+        return False
+
+    # For other ImportErrors, try to find the module spec for any possible path
+    for mp in possible_module_paths:
+        try:
+            spec = util.find_spec(mp)
+            if spec is not None and spec.origin:
+                # Module exists but has import issues - internal error
+                return False
+        except (ImportError, ModuleNotFoundError, ValueError):
+            continue
+
+    # If no module spec found for any path, treat as path error
+    return True
+
